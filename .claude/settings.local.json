{
  "permissions": {
    "allow": [
      "Bash(git commit:*)",
      "Bash(git add:*)",
      "Bash(git push:*)",
      "Bash(xargs ls:*)",
      "Bash(cat .claude/agents/*)",
      "WebSearch",
      "Bash(npm run:*)",
      "Bash(git rm:*)",
      "Bash(git rebase:*)",
      "Bash(git diff:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(python:*)"
    ]
  },
  "hooks": {
    "pre-commit": "python .claude/hooks/check-commit-related.ts"
  }
}
