{
  "permissions": {
    "allow": [
      "Bash(git commit:*)",
      "Bash(git add:*)",
      "Bash(git push:*)",
      "Bash(xargs ls:*)",
      "Bash(cat .claude/agents/*)",
      "WebSearch",
      "Bash(npm run:*)",
      "Bash(git rm:*)",
      "Bash(git rebase:*)",
      "Bash(git diff:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(python:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash(git commit:*)",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/check-commit-related.py"
          }
        ]
      }
    ]
  }
}
