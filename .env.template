# Auth middleware.
JWT_SECRET=replace-with-a-secure-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60


# Agent tools requiring human approval. Use a JSON array with 1-3 tool names.
HIL_APPROVAL_TOOLS=["write_file","edit_file","execute"]


# PostgreSQL stores users, conversations, messages, agent runs, and checkpoints.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/multi_agent_s2c

# Redis is optional. Set ENABLE_RUN_QUEUE=true to use ARQ background jobs and Redis Stream run events.
ENABLE_RUN_QUEUE=false
AGENT_EVENT_PERSIST_ENABLED=true
REDIS_URL=redis://localhost:6379/0
ARQ_QUEUE_NAME=agent-runs
ARQ_MAX_JOBS=64
REDIS_POOL_MAX_CONNECTIONS=20
RUN_STREAM_POLL_TIMEOUT_MS=15000
RUN_STREAM_MAX_LEN=10000


# MinIO stores uploaded images and documents.
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=app-attachments
MINIO_SECURE=false
MINIO_REGION=
MINIO_PRESIGN_EXPIRE_SECONDS=600


# Local/project retrieval providers and search limits.
GRAPH_KNOWLEDGE_PROVIDER=lightrag
VECTOR_KNOWLEDGE_PROVIDER=milvus
LIGHTRAG_WORKING_DIR=./save/lightrag
LIGHTRAG_WORKSPACE=default
LIGHTRAG_LLM_MODEL=
LIGHTRAG_EMBEDDING_MODEL=dashscope/text-embedding-v4
LIGHTRAG_EMBEDDING_DIM=1024
LIGHTRAG_EMBEDDING_MAX_TOKEN_SIZE=8192
MILVUS_URI=http://localhost:19530
MILVUS_TOKEN=
MILVUS_DB_NAME=
TAVILY_API_KEY=
SEARCH_MAX_CONCURRENCY=4
SEARCH_ROUTE_TIMEOUT_SECONDS=8
LOCAL_REFERENCE_ROOT=


# MCP Server 独立部署并常驻；这里只配置远程连接，不由后端启停，也不支持 stdio。
# 值为 JSON；未配置时 MCPService 返回空工具表。
# 示例：{"ocr":{"transport":"streamable_http","url":"http://localhost:8000/mcp"}}
MCP_SERVERS={}
MCP_CONNECT_TIMEOUT_SECONDS=15
MCP_TOOL_CALL_TIMEOUT_SECONDS=120
MCP_MAX_CONCURRENCY=16


# 旧版 .doc 解析使用外部 Apache Tika Server；留空时 DocParser 返回配置错误。
TIKA_SERVER_URL=


# 百度 Unlimited-OCR 托管 API。未配置密钥时会自动回退到其他 OCR。
UNLIMITED_OCR_API_URL=https://aip.baidubce.com/rest/2.0/brain/online/v2/unlimited-ocr-parser/task
UNLIMITED_OCR_API_KEY=
UNLIMITED_OCR_SECRET_KEY=
UNLIMITED_OCR_POLL_INTERVAL_SECONDS=5
UNLIMITED_OCR_POLL_TIMEOUT_SECONDS=600


# 沙箱供应服务。若调用方运行在容器内，请改为容器可访问的地址。
SANDBOX_PROVISIONER_URL=http://localhost:8002


# Langfuse tracing is optional. Disable it for local runs without Langfuse keys.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_TRACING_ENABLED=true
LANGFUSE_TRACING_ENVIRONMENT=development


# Fill only the providers used by the configured models.
DASHSCOPE_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
